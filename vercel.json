{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3.2.28"
    }
  },
  "rewrites": [
    {
      "source": "/api(.*)",
      "destination": "/api$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}